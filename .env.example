# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000                          # Port aplikasi berjalan (default: 3000)
NODE_ENV=development               # Environment: development | production | test
CORS_ORIGIN=http://localhost:5173  # URL frontend yang diizinkan akses API
# Beberapa origin: http://localhost:5173,https://yourdomain.com

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your-super-secret-key-here        
JWT_EXPIRES_IN=7d                            # Durasi token berlaku (contoh: 1h, 7d, 30d)

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME"
# Contoh lokal  → postgresql://dev_user:password123@localhost:5432/myapp_db
# Contoh cloud  → postgresql://user:pass@db.supabase.co:5432/postgres