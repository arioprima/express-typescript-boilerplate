enum SwapRequestStatus {
    PENDING
    ACCEPTED
    REJECTED
    CANCELLED
}

model SwapRequest {
    id                    String            @id @default(uuid())
    tenant_id             String
    requester_id          String
    requester_schedule_id String
    target_id             String
    target_schedule_id    String?
    reason                String?
    status                SwapRequestStatus @default(PENDING)
    responded_at          DateTime?
    approved_by           String?
    approved_at           DateTime?
    rejection_reason      String?
    created_at            DateTime          @default(now())
    updated_at            DateTime          @updatedAt
    deleted_at            DateTime?

    tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
    requester          User      @relation("SwapRequestRequester", fields: [requester_id], references: [id], onDelete: Cascade)
    target             User      @relation("SwapRequestTarget", fields: [target_id], references: [id], onDelete: Cascade)
    requester_schedule Schedule  @relation("SwapRequestRequesterSchedule", fields: [requester_schedule_id], references: [id], onDelete: Cascade)
    target_schedule    Schedule? @relation("SwapRequestTargetSchedule", fields: [target_schedule_id], references: [id], onDelete: Cascade)
    approver           User?     @relation("SwapRequestApprovedByUser", fields: [approved_by], references: [id], onDelete: SetNull)

    @@index([tenant_id])
    @@index([requester_id])
    @@index([target_id])
    @@index([status])
    @@map("swap_requests")
}
