enum AttendanceStatus {
    PENDING
    APPROVED
    REJECTED
    REVISED
}

model Attendance {
    id                    String            @id @default(uuid())
    tenant_id             String
    schedule_id           String
    user_id               String
    outlet_id             String
    clock_in_at           DateTime?
    clock_in_method       String?
    clock_in_latitude     Decimal?          @db.Decimal(10, 8)
    clock_in_longitude    Decimal?          @db.Decimal(11, 8)
    clock_in_photo_url    String?
    clock_in_device_info  Json?
    clock_out_at          DateTime?
    clock_out_method      String?
    clock_out_latitude    Decimal?          @db.Decimal(10, 8)
    clock_out_longitude   Decimal?          @db.Decimal(11, 8)
    clock_out_photo_url   String?
    clock_out_device_info Json?
    total_hours           Decimal?          @db.Decimal(5, 2)
    overtime_hours        Decimal           @default(0) @db.Decimal(5, 2)
    status                AttendanceStatus? @default(PENDING)
    notes                 String?
    approved_by           String?
    approved_at           DateTime?
    created_at            DateTime          @default(now())
    updated_at            DateTime          @updatedAt
    deleted_at            DateTime?

    tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
    schedule Schedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
    user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
    outlet   Outlet   @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
    approver User?    @relation("AttendanceApprovedByUser", fields: [approved_by], references: [id], onDelete: SetNull)

    @@index([tenant_id])
    @@index([schedule_id])
    @@index([user_id])
    @@index([outlet_id, clock_in_at])
    @@index([status])
    @@map("attendances")
}
