model Holiday {
    id          String    @id @default(uuid())
    tenant_id   String?
    name        String
    date        DateTime
    is_national Boolean   @default(false)
    created_at  DateTime  @default(now())
    updated_at  DateTime  @updatedAt
    deleted_at  DateTime?

    tenant Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

    @@index([is_national])
    @@index([date])
    @@map("holidays")
}
