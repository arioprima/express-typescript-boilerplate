model User {
    id                 String    @id @default(uuid())
    tenant_id          String
    role_id            String
    email              String    @unique
    phone              String?
    password           String
    full_name          String
    avatar_url         String?
    employee_code      String?
    hourly_rate        Decimal?  @db.Decimal(12, 2)
    max_hours_per_week Int?      @default(40)
    is_active          Boolean   @default(true)
    email_verified_at  DateTime?
    last_login_at      DateTime?
    fcm_token          String?
    whatsapp_opted_in  Boolean   @default(true)
    created_at         DateTime  @default(now())
    updated_at         DateTime  @updatedAt
    deleted_at         DateTime?

    tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
    role   Role   @relation(fields: [role_id], references: [id], onDelete: Restrict)

    @@index([tenant_id])
    @@index([email])
    @@index([phone])
    @@index([employee_code])
    @@map("users")
}
